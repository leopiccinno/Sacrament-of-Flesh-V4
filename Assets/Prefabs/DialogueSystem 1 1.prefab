  dialogueText: {fileID: 5483892786032114775}
  blackOverlay: {fileID: 0}
  useNoteInteraction: 1
  button: {fileID: 1965978352010738253}
  bigNotePanel: {fileID: 4238542368814996519}
  nextSceneButton: {fileID: 773282601651923242}
  characterName: YOU
  introDialogueLines:
  - The turn around as your view moves back on the bottle of poison you were just
    about to drink.
  - "\u201CWhat am I doing...? Oh lord...\u201D"
  - You walk back to the table to close the bottle...
  - ...but as you walk over you notice a card lying next to it.
  - "You don\u2019t remember placing a card here. You would remember."
  - '*Flick*'
  - You pick up the card, inspecting it closely.
  afterNoteDialogueLines:
  - Something in your heart tells you to put this card in your pocket, this may become
    handy in future situations.
  pauseMarker: '[PAUSE]'
  useBlackOverlay: 1
  revealBackgroundAfterLine: 7
  fadeBlackOverlay: 1
  fadeDuration: 1
  typingSpeed: 0.03
