  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogueController
  textBox: {fileID: 4527329577849374522}
  nameText: {fileID: 8541215426345585852}
  dialogueText: {fileID: 8251402667053240794}
  blackOverlay: {fileID: 0}
  useNoteInteraction: 1
  button: {fileID: 7689579346985327630}
  bigNotePanel: {fileID: 2535656437005428883}
  nextSceneButton: {fileID: 8795090234338252617}
  characterName: YOU
  introDialogueLines:
  - 'A loud knock on the door interrupts your pathetic attempt to escape your

    feelings.'
  - '*KNOCK*'
  - "Another knock. This time it\u2019s much slower. Not your imagination."
  - Something- or someone- is standing on the other side of your door.
  - "\u201CWho\u2019s there? What do you want?\u201D"
  - ...
  - No answer.
  - '*Shhhhnk*'
  - You watch as something slides beneath your door.
  - '[PAUSE]'
  - A piece of paper, thin and uneven, is now laying on the wooden floor.
  - You wait.
  - '*Thud*'
  - 'Finally, you set the poison back on the table and rush over to the door to pick
    up

    the paper.'
  afterNoteDialogueLines:
  - "\u201CWhat in the world...?\u201D"
  pauseMarker: '[PAUSE]'
  useBlackOverlay: 1
  revealBackgroundAfterLine: 7
  fadeBlackOverlay: 1
  fadeDuration: 1
  typingSpeed: 0.03
