    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[0]'
      value: You stand up and pull the door open.
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[1]'
      value: The night stretches out before you.
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[2]'
