      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[3]'
      value: Dark. Empty.
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[4]'
      value: 'The trees stand motionless, their dark silhouettes contrasting the
        pale light of the

        moon.'
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[5]'
      value: No sign of anyone ever being here.
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[6]'
      value: A chill runs down your spine.
      objectReference: {fileID: 0}
    - target: {fileID: 7605751305664041739, guid: 1a9b2516d4d1c094abff5f4067193259, type: 3}
      propertyPath: 'introDialogueLines.Array.data[7]'
