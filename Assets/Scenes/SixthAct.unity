      useCardChoiceAfterIntro: 1
      flagRules:
      - ruleName: Already took ash route
        requiredFlags:
        - ASHBURN
        forbiddenFlags: []
        dialogueLines:
        - His smile drops.
        - "\u201CI just think, you may need to stop hanging around withered souls
          first.\u201D"
        - "\u201CJust a word of advice.\u201D"
        - Ozric turns back around and leaves.
        - ...
        speakerChanges:
        - lineIndex: 1
          speakerName: Ozric
        - lineIndex: 2
          speakerName: Ozric
        setRouteFlag: 0
        routeFlagToSet: 
        countsAsSpecialRoute: 0
      specialCard: {fileID: 11400000, guid: 85740473d308047449365116d321447f, type: 2}
      specialRouteFlag: OZRICETERNAL
      normalRouteFlag: GAMEOVER
      specialCardDialogueLines:
      - "Ozric let\u2019s out a quiet breath."
      - "\u201CI see myself in you. You\u2019re a good soul.\u201D"
      - ...
      - "\u201CTell me, do you know what peace is?\u201D"
      - "\u201CTrue peace.\u201D"
      - ...
      - "\u201CI\u2019ve spent years searching for it...\u201D"
      - "\u201CAnd when I stopped searching... I found it.\u201D"
      - A faint smile appears on his face.
      - "\u201CPerhaps one day, you will too.\u201D"
      - "\u201CI shall have the honour of welcoming you.\u201D"
      - "\u201CWe are friends now.\u201D"
      - "\u201CRight?\u201D"
      - You stay silent for a while.
      - "\u201CYes, Ozric. You are my friend.\u201D"
      - "\u201CWell, see you around. Friend.\u201D"
      - Smiling, he turns back around and leaves.
      - ...
      specialCardSpeakerChanges:
      - lineIndex: 1
        speakerName: Ozric
      - lineIndex: 3
